/*
The Business Problem:
The Executive Board is reviewing senior software engineering strategy in English-speaking markets. 
They are explicitly ignoring entry-level positions and want to inspect top-tier roles.
The Director needs a report showing all job postings where the title contains 'Senior', 
located in 'Texas', 'California', or 'New York', where at least one salary metric is populated.
*/

SELECT 
    job_title, 
    job_location, 
    salary_year_avg, 
    salary_rate,
    DENSE_RANK() OVER(ORDER BY salary_year_avg DESC) AS RANK_LIST
FROM job_postings_fact
WHERE job_title LIKE '%Senior%' 
  AND job_location IN ('Texas', 'New York', 'California')
  AND (salary_year_avg IS NOT NULL OR salary_rate IS NOT NULL)
ORDER BY salary_year_avg DESC
LIMIT 10;
